{
    "name": "linkandroid",
    "version": "2.0.0-beta",
    "main": "dist-electron/main/index.js",
    "description": "Link android to PC easily",
    "author": "ModStartLib",
    "homepage": "https://linkandroid.com",
    "license": "Apache-2.0",
    "private": true,
    "keywords": [
        "electron",
        "rollup",
        "vite",
        "vue3",
        "vue"
    ],
    "debug": {
        "env": {
            "VITE_DEV_SERVER_URL": "http://127.0.0.1:3344/"
        }
    },
    "type": "module",
    "scripts": {
        "dev": "vite",
        "dev:mac": "pkill -f linkandroid; vite",
        "dev:mac:pre": "export ELECTRON_ENV_PROD=1 && pkill -f linkandroid; vite",
        "dev:win": "chcp 65001 && vite",
        "dev:win:pre": "chcp 65001 && set ELECTRON_ENV_PROD=1 && vite",
        "dev:debug": "vite --debug",
        "build:preview": "node scripts/build-preview.mjs",
        "build": "npm run format && node scripts/build.mjs",
        "build:win": "npm run format && cross-env VITE_RELEASE=1 vite build && electron-builder --win",
        "build:mac": "npm run format && cross-env VITE_RELEASE=1 vite build && electron-builder --mac",
        "build:mac-arm": "npm run format && cross-env VITE_RELEASE=1 vite build && electron-builder --mac --arm64",
        "build:mac-native": "npm run format && cross-env VITE_RELEASE=1 vite build && electron-builder --config _temp/electron-builder-native-config.json --mac",
        "build:linux": "npm run format && cross-env VITE_RELEASE=1 vite build && electron-builder --linux",
        "dev:seed": "tsx test/dev-seed.ts",
        "screenshot": "tsx test/screenshot.ts",
        "preview": "vite preview",
        "postinstall": "electron-builder install-app-deps",
        "postuninstall": "electron-builder install-app-deps",
        "re-sqlite": "npx electron-rebuild -f -w better-sqlite3",
        "format": "prettier --write --log-level warn \"src/**/*.{ts,tsx,vue,js}\" \"electron/**/*.{ts,tsx,js}\""
    },
    "devDependencies": {
        "@arco-design/web-vue": "^2.55.3",
        "@electron/notarize": "^2.5.0",
        "@iconify-json/lucide": "^1.2.112",
        "@iconify-json/mdi": "^1.2.3",
        "@playwright/test": "^1.60.0",
        "@types/express": "^5.0.6",
        "@types/lodash-es": "^4.17.12",
        "@types/pngjs": "^6.0.5",
        "@types/splitpanes": "^2.2.6",
        "@typescript-eslint/eslint-plugin": "^8.59.2",
        "@typescript-eslint/parser": "^8.59.2",
        "@vitejs/plugin-vue": "^5.0.4",
        "autoprefixer": "^10.4.19",
        "cross-env": "^10.1.0",
        "electron": "^29.1.1",
        "electron-builder": "^24.13.3",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.9.1",
        "less": "^4.2.0",
        "pixelmatch": "^7.2.0",
        "pngjs": "^7.0.0",
        "postcss": "^8.4.39",
        "prettier": "^3.8.3",
        "tailwindcss": "^3.4.4",
        "tsx": "^4.21.0",
        "typescript": "^5.4.2",
        "unplugin-icons": "^23.0.1",
        "unplugin-vue-components": "^32.0.0",
        "vite": "^5.1.5",
        "vite-plugin-electron": "^0.28.4",
        "vite-plugin-electron-renderer": "^0.14.5",
        "vite-plugin-html": "^3.2.2",
        "vue": "^3.4.21",
        "vue-eslint-parser": "^10.4.0",
        "vue-tsc": "^2.0.6"
    },
    "dependencies": {
        "@babel/runtime": "^7.24.8",
        "@codemirror/lang-javascript": "^6.2.5",
        "@codemirror/lang-json": "^6.0.2",
        "@codemirror/lang-markdown": "^6.5.0",
        "@codemirror/lang-python": "^6.2.1",
        "@codemirror/lang-yaml": "^6.1.3",
        "@codemirror/language": "^6.12.3",
        "@codemirror/legacy-modes": "^6.5.3",
        "@codemirror/state": "^6.6.0",
        "@codemirror/theme-one-dark": "^6.1.3",
        "@codemirror/view": "^6.43.1",
        "@devicefarmer/adbkit": "^3.2.6",
        "@electron-toolkit/preload": "^3.0.1",
        "@electron-toolkit/utils": "^3.0.0",
        "@electron/remote": "^2.1.2",
        "@types/showdown": "^2.0.6",
        "@types/ws": "^8.18.1",
        "@xterm/addon-fit": "^0.10.0",
        "@xterm/xterm": "^5.5.0",
        "@zxing/browser": "^0.1.5",
        "@zxing/library": "^0.21.3",
        "axios": "^1.7.2",
        "baseline-browser-mapping": "^2.10.36",
        "better-sqlite3": "^12.2.0",
        "bonjour-service": "^1.3.0",
        "caniuse-lite": "^1.0.30001799",
        "chardet": "^2.0.0",
        "codemirror": "^6.0.2",
        "croner": "^10.0.1",
        "date-and-time": "^3.4.1",
        "dayjs": "^1.11.12",
        "electron-context-menu": "^4.0.4",
        "express": "^5.2.1",
        "fix-path": "^4.0.0",
        "iconv": "^3.0.1",
        "iconv-lite": "^0.6.3",
        "js-base64": "^3.7.7",
        "lodash-es": "^4.17.21",
        "lucide-vue-next": "^0.563.0",
        "nodejs-base64": "^2.0.0",
        "pinia": "^2.1.7",
        "qrcode": "^1.5.4",
        "showdown": "^2.1.0",
        "splitpanes": "^3.1.5",
        "systeminformation": "^5.25.11",
        "tiny-emitter": "^2.1.0",
        "vue-command": "^35.2.1",
        "vue-i18n": "^9.13.1",
        "vue-router": "^4.4.0",
        "ws": "^8.19.0"
    },
    "optionalDependencies": {
        "node-mac-permissions": "^2.4.0"
    }
}
